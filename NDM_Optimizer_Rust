def _lerp_color(
    lo: Tuple[int,int,int], hi: Tuple[int,int,int], t: float,
) -> str:
    r = int(lo[0] + (hi[0]-lo[0]) * t)
    g = int(lo[1] + (hi[1]-lo[1]) * t)
    b = int(lo[2] + (hi[2]-lo[2]) * t)
    return f"{r:02X}{g:02X}{b:02X}"


