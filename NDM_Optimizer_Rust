    if SPREAD_METRIC:
        rows += [
            ("── Spread metric", ""),
            ("HNS q value",      str(HNS_Q)),
            ("HNS formula",      "N · (Σpᵢ^q)^(1/(1-q));  q=2 → N²/Σhᵢ²"),
